# Commodity extraction
COMMODITY_SYMBOLS=CL=F,GC=F,ZW=F

# Warehouse target
WAREHOUSE_TYPE=postgres
WAREHOUSE_HOST=postgres
WAREHOUSE_PORT=5432
WAREHOUSE_DB=commodity_lakehouse
WAREHOUSE_USER=loader
WAREHOUSE_PASSWORD=loader
WAREHOUSE_SQLALCHEMY_URL=postgresql+psycopg2://loader:loader@postgres:5432/commodity_lakehouse

# Alerts and lineage
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
OPENLINEAGE_URL=http://marquez:5000

# Airflow metadata database (docker-compose)
POSTGRES_USER=loader
POSTGRES_PASSWORD=loader
POSTGRES_DB=commodity_lakehouse

# Airflow runtime
AIRFLOW_UID=50000
AIRFLOW__WEBSERVER__SECRET_KEY=change_me
AIRFLOW_PIP_ADDITIONAL_REQUIREMENTS=
